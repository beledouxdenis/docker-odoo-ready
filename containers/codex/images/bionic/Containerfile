FROM localhost/odoo:bionic

RUN apt-get update && apt-get install -y --no-install-recommends gnupg \
 && apt-get purge -y nodejs npm --autoremove \
 && mkdir -p /etc/apt/keyrings \
 # Legacy NodeSource Node 16 key for bionic: 1655A0AB68576280
 && curl -fsSL "https://keyserver.ubuntu.com/pks/lookup?op=get&search=0x9FD3B784BC1C6FC31A8A0A1C1655A0AB68576280" \
    | gpg --dearmor -o /etc/apt/keyrings/nodesource-legacy.gpg \
 && echo "deb [signed-by=/etc/apt/keyrings/nodesource-legacy.gpg] https://deb.nodesource.com/node_16.x bionic main" \
    > /etc/apt/sources.list.d/nodesource.list \
 && apt-get update \
 && apt-get install -y --no-install-recommends bubblewrap git nodejs postgresql-client \
 && npm install -g @openai/codex \
 && rm -rf /var/lib/apt/lists/*
