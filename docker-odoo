#!/usr/bin/env python3
import argparse
import os
import platform
import re
import subprocess
from pathlib import Path

if platform.machine() in {"aarch64", "arm64"}:
    IMAGES = [(18.0, "trixie"), (14.0, "bookworm"), (6.1, "bionic")]
else:
    IMAGES = [(18.0, "noble"), (14.0, "jammy"), (6.1, "bionic")]
SRC = Path(os.environ.get("ODOO_SRC", Path.home() / "src"))
COMMUNITY = SRC / "odoo"
ODOO_COMMANDS = {"shell", "scaffold", "cloc"}

parser = argparse.ArgumentParser(add_help=False)
parser.add_argument("--branch", "-b", help="Odoo branch", default="master")
parser.add_argument("--image", help="Docker image")
parser.add_argument("--build", help="Force rebuilding the image", action="store_true")
parser.add_argument(
    "--volume",
    "-v",
    action="append",
    default=[],
    help="Additional volume, same syntax as podman -v/--volume. Can be repeated.",
)
parser.add_argument("--http-port", "-p", help="HTTP Port", default="8069")

args, extra_args = parser.parse_known_args()

longpolling_port = str(int(args.http_port) + 3)
debug_port = 5678 + (int(args.http_port) - 8069)

if not (odoo_rc := Path.home() / ".odoorc").exists():
    odoo_rc.touch()

command = ["podman-compose", "-f", "docker-compose.yml"]

command += ["run"]

if args.build:
    command += ["--build"]

command += ["--rm", "-p", f"{debug_port}:5678"]

command += [arg for mount in args.volume for arg in ["-v", mount]]

if not extra_args or extra_args[0] not in ODOO_COMMANDS:
    command += [
        "-p",
        f"127.0.0.1:{args.http_port}:8069",
        "-p",
        f"127.0.0.1:{longpolling_port}:8072",
    ]

# Name of the service in the docker-compose file
command += ["odoo"]

if extra_args and not extra_args[0].startswith("-") and extra_args[0] not in ODOO_COMMANDS:
    command += extra_args
    docker_file = args.image if args.image else IMAGES[0][1]
else:
    odoo_branch = args.branch
    extra_args.extend(["--branch", args.branch])
    odoo_path = COMMUNITY / odoo_branch

    odoo_release_file = next(
        path / "release.py" for path in [odoo_path / "odoo", odoo_path / "openerp"] if path.exists()
    )
    odoo_version = re.search(r"version_info = \((.*)\)", odoo_release_file.read_text())
    odoo_version = float(".".join(re.findall(r"\d+", "".join(odoo_version.groups()[0].split(",")[:2]))))

    docker_file = args.image if args.image else next(image for version, image in IMAGES if odoo_version >= version)

    command += ["odoo", *extra_args]

cwd = os.path.dirname(os.path.realpath(__file__))
subprocess.run(command, env=dict(os.environ, DOCKERFILE=docker_file), cwd=cwd, check=False)
